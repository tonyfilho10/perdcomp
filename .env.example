# Prisma — conexão direta ao Postgres do Supabase (Project Settings > Database > Connection string)
DATABASE_URL="postgresql://postgres:[SUA-SENHA]@db.<project-ref>.supabase.co:5432/postgres"

# Supabase client (browser + server). Pegue em Project Settings > API Keys.
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon/publishable key>"

# Apenas server-side. NÃO prefixar com NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY="<secret key>"

# Usado para assinar o cookie de sessão (login é via RPC verificar_login, não Supabase Auth).
SESSION_SECRET="<gere com: openssl rand -base64 32>"
